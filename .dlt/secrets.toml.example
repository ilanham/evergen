# Copy this file to .dlt/secrets.toml and fill in your credentials.
# secrets.toml is gitignored — never commit it.
# Only required when EVERGEN_ENV=prod.

[destination.snowflake.credentials]
database  = "EVERGEN"
host      = "your-account.snowflakecomputing.com"
username  = ""
password  = ""
warehouse = ""
role      = ""
