# ─── Environment selector ────────────────────────────────────────────────────
# "local"  →  DuckDB  (no credentials required)
# "prod"   →  Snowflake  (set all SNOWFLAKE_* vars below)
EVERGEN_ENV=local

# ─── DuckDB (local only) ─────────────────────────────────────────────────────
DUCKDB_PATH=local.duckdb

# ─── Snowflake (required when EVERGEN_ENV=prod) ───────────────────────────────
# Also set these in .dlt/secrets.toml and transform/profiles.yml
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=EVERGEN
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# ─── Dagster ─────────────────────────────────────────────────────────────────
# For local dev (no Docker), dagster uses SQLite by default.
# For Docker, this is set to /dagster_home inside the container.
DAGSTER_HOME=.dagster_home
