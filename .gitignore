# =============================================================================
# Evergen Data Platform — .gitignore
# Stack: Python, Dagster, dlt, dbt, Snowflake, DuckDB (local dev alt)
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials and Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.toml.local
.dlt/secrets.toml
transform/profiles.yml
profiles.yml
snowflake_credentials.json
credentials.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
MANIFEST
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pyright/
.ruff_cache/

# Testing
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.cover
*.log

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Pyenv
.python-version

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
transform/target/
transform/dbt_packages/
transform/logs/
transform/profiles.yml

# dbt compiled artifacts (regenerated by dbt build/compile)
target/
dbt_packages/
logs/

# -----------------------------------------------------------------------------
# dlt
# -----------------------------------------------------------------------------
.dlt/secrets.toml
.dlt/local.toml
# Keep .dlt/config.toml (non-secret) — but ignore pipeline state
.dlt/pipelines/
pipeline_state/

# -----------------------------------------------------------------------------
# Dagster
# -----------------------------------------------------------------------------
# Dagster local instance storage (run history, event log, schedules)
$DAGSTER_HOME/
.dagster/
dagster_home/

# Dagster build artifacts
.dagster_build/

# -----------------------------------------------------------------------------
# DuckDB (local development alternative to Snowflake)
# -----------------------------------------------------------------------------
*.duckdb
*.duckdb.wal
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon?

# macOS directory metadata
__MACOSX/

# -----------------------------------------------------------------------------
# IDEs and Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Source files (not to be committed — provided separately)
# Uncomment this block if CSV source files should NOT be in the repo
# -----------------------------------------------------------------------------
# files/source1_orders.csv
# files/source2_fulfillment.csv

# -----------------------------------------------------------------------------
# Build and packaging artifacts
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.tar.bz2
*.tgz

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
.hypothesis/
